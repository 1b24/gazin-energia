# --- DB ---
DATABASE_URL="postgresql://user:password@localhost:5432/gazin?schema=public"

# --- Auth (NextAuth v5) ---
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=""
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Admin inicial criado pelo seed. OBRIGATÓRIO em produção; mínimo 12 chars.
# Em dev sem essa variável, o seed gera uma senha aleatória e imprime no console.
SEED_ADMIN_PASSWORD=""

# --- Storage (uploads) ---
# Se as 4 variáveis abaixo estiverem setadas, o storage usa S3-compatível
# (Cloudflare R2 / AWS S3 / MinIO). Caso contrário, fallback local em
# `private-uploads/` — só funciona em dev/single-server (não Vercel).
STORAGE_S3_ENDPOINT="" # ex: https://<accountid>.r2.cloudflarestorage.com
STORAGE_S3_REGION="auto"
STORAGE_S3_ACCESS_KEY_ID=""
STORAGE_S3_SECRET_ACCESS_KEY=""
STORAGE_S3_BUCKET=""

# --- Rate limiting (login) ---
# Vercel KV (Redis) via Upstash. Setadas? rate limit usa KV.
# Não setadas? fallback in-memory por IP (single-server, ok pra dev).
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
