# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# raw data dumps from legacy system (kept locally only)
/data/raw/*
!/data/raw/.gitkeep
/data/new-import/
/data/raw-backups/
/data/db-backups/
/data/xlsx-backup/*
!/data/xlsx-backup/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# graphify (índice de navegação local — regenerado via `graphify update .`)
/graphify-out/

# uploads locais (dev). Em produção, R2 — vide .env.example.
/public/uploads/
/private-uploads/

# runtime / dev artifacts locais (logs, bancos PGLite, caches de smoke test)
# Mantidos fora do repo — regenerados a cada execução.
*.log
/.pglite-*/
/.pglite-*.log
/.prisma-dev-*/
/.prisma-dev-*.log
/.next-*.log
/.next-*.cmd.log
/.db-live*.log
/.local-start*.log
/.localhost-runner*.log
/.npm-cache/
/.run-pglite-local.cmd
