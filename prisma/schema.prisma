model CronogramaLimpeza {
  id     String  @id @default(cuid())
  zohoId String? @unique

  realizado   String?
  statusGeral StatusManutencao @default(pendente)

  usina        Usina?  @relation(fields: [usinaId], references: [id], onDelete: Restrict)
  usinaId      String?
  nomeUsinaRaw String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  itens LimpezaItem[]

  @@index([usinaId])
  @@index([statusGeral])
  @@index([deletedAt])
}

/// Value-object filho de CronogramaLimpeza — `Cascade` intencional.
model LimpezaItem {
  id            String            @id @default(cuid())
  cronograma    CronogramaLimpeza @relation(fields: [cronogramaId], references: [id], onDelete: Cascade)
  cronogramaId  String
  ordem         Int
  dataPlanejada DateTime?
  dataConclusao DateTime?
  status        StatusManutencao?
  fotoUrl       String?

  @@unique([cronogramaId, ordem])
  @@index([cronogramaId])
  @@index([dataPlanejada])
}

model ManutencaoPreventiva {
  id     String  @id @default(cuid())
  zohoId String? @unique

  status               StatusManutencao @default(pendente)
  dataExecucao         DateTime?
  dataConclusao        DateTime?
  laudoTecnico         String?
  fotosUsina           String?
  checklistVerificacao String?

  usina        Usina?  @relation(fields: [usinaId], references: [id], onDelete: Restrict)
  usinaId      String?
  nomeUsinaRaw String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([usinaId])
  @@index([status])
  @@index([dataExecucao])
  @@index([deletedAt])
}

// =============================================================================
