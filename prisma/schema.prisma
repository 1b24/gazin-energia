  deletedAt DateTime?

  @@index([deletedAt])
}

// =============================================================================
// TARIFAS — comparação fornecedor (mercado livre) × distribuidora (cativo)
// =============================================================================

/// Concessionária de distribuição regulada (Energisa, Copel, Enel, Light,
/// Cemig, etc.). Tarifa publicada ANEEL; entidade global, pouco volume
/// (~10 registros típicos), cadastrada manualmente ou via seed.
model Distribuidora {
  id          String  @id @default(cuid())
  nome        String  @unique
  /// Sigla curta usada em rótulos compactos. Ex: "ENERGISA-MS", "COPEL".
  sigla       String?
  /// Código oficial ANEEL — referência externa, não usado em joins.
  codigoAneel String?
  /// UF principal de atuação. Distribuidora pode cobrir várias UFs, mas
  /// para o cadastro inicial guardamos só a principal.
  uf          UF?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tarifas TarifaEnergia[]

  @@index([uf])
  @@index([deletedAt])
}

/// Tarifa de kWh — vigente em um intervalo. Polimórfica: pertence a um
/// `Fornecedor` (mercado livre) OU a uma `Distribuidora` (cativo regulado),
/// nunca aos dois ao mesmo tempo. O enum `origem` indica qual FK é válida.
///
/// Histórico: cada reajuste cria registro novo (com `vigenciaInicio` da
/// nova tarifa). Para fechar a vigência da anterior, preenche
/// `vigenciaFim` dela. `vigenciaFim = null` significa tarifa vigente.
model TarifaEnergia {
  id     String       @id @default(cuid())
  origem OrigemTarifa

  // FK polimórfica — exatamente uma das duas deve ser preenchida.
  // A consistência (`origem === "fornecedor"` ⇒ fornecedorId != null) é
  // garantida no schema Zod (lib/schemas/tarifa-energia.ts), não no DB —
  // Prisma não tem CHECK condicional nativo.
  fornecedor      Fornecedor?    @relation(fields: [fornecedorId], references: [id], onDelete: Restrict)
  fornecedorId    String?
  distribuidora   Distribuidora? @relation(fields: [distribuidoraId], references: [id], onDelete: Restrict)
  distribuidoraId String?

  /// R$/kWh — precisão 6 decimais para acomodar tarifas ANEEL e contratos
  /// (ex: 0,530520 R$/kWh). Decimal evita ruído de float.
  valorPonta     Decimal? @db.Decimal(12, 6)
  valorForaPonta Decimal? @db.Decimal(12, 6)

  vigenciaInicio DateTime
  /// null = tarifa atual. Preencher quando uma tarifa nova entrar em vigor.
  vigenciaFim    DateTime?

  /// Classe de tensão à qual essa tarifa se aplica. Quando preenchido, o
  /// lookup só usa essa tarifa pra UCs da mesma classe. Quando null,
  /// funciona como tarifa "genérica" pra UCs sem classe cadastrada.
  classeTensao ClasseTensao?

  /// Específico de distribuidora — verde / azul / convencional / branca.
  /// Para fornecedor (mercado livre) costuma ficar null.
  modalidade String?

  observacao String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([origem])
  @@index([fornecedorId])
  @@index([distribuidoraId])
  @@index([classeTensao])
  @@index([vigenciaInicio])
  @@index([deletedAt])
}
