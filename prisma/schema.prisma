// Prisma 7 note: `url` lives in prisma.config.ts, not here.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum UF {
  AC
  AL
  AM
  AP
  BA
  CE
  DF
  ES
  GO
  MA
  MG
  MS
  MT
  PA
  PB
  PE
  PI
  PR
  RJ
  RN
  RO
  RR
  RS
  SC
  SE
  SP
  TO
}

enum TipoGD {
  GD1
  GD2
  GD3
}

enum LocalInstalacao {
  telhado
  solo
}

enum StatusUsina {
  em_implantacao
  operacional
  manutencao
  desativada
}

enum TipoProcesso {
  judicial
  administrativo
}

enum StatusManutencao {
  pendente
  em_andamento
  concluida
}

enum TipoOrcamento {
  despesa_direta
  outro
}

enum StatusEntidade {
  ativo
  inativo
}

// =============================================================================
// CORE
// =============================================================================

/// Filial — unidade consumidora (UC, distribuidora, grupo tarifário). 465 rows.
/// JSON Zoho atual: "Usinas Relatório.json" (nome confuso na origem).
model Filial {
  id     String  @id @default(cuid())
  zohoId String? @unique // idempotência do seed contra a fonte legada

  codigo                    String?
  cd                        String?
  mercadoLivre              String?
  percentualAbsorcaoUsp     Decimal?  @db.Decimal(7, 2)
  uc                        String?
  uc2                       String?
  uc3                       String?
  municipio                 String?
  uf                        UF?
  senha                     String?
  usuario                   String?
  grupo                     String?
  distribuidora             String?
  cnpj                      String?
  filialClimatizada         String?
  dataClimatizacaoPlanejada DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  usinas                  Usina[]
  consumos                Consumo[]
  fornecedoresAbrangencia Fornecedor[]

  @@index([codigo])
  @@index([cnpj])
  @@index([uf])
  @@index([deletedAt])
}

/// Usina geradora solar. 18 rows. Renomeado conforme BRIEF: kWp → kW.
model Usina {
  id     String  @id @default(cuid())
  zohoId String? @unique

  nome                String
  ccUsinas            String?
  localInstalacao     LocalInstalacao? // antes era `tipo`
  tipoGd              TipoGD?
  cnpj                String?
  uc                  String?
  potenciaInstaladaKw Decimal?         @db.Decimal(10, 2) // antes "Pot_ncia_kWp"
  potenciaProjetadaKw Decimal?         @db.Decimal(10, 2) // antes "Pot_ncia_kWp1"
  metaKwhMes          Int? // energia mensal: kWh, ok
  inicioOperacao      DateTime?
  autoProdutora       Boolean?
  quantasFlAtende     Int?
  municipio           String?
  uf                  UF?
  investimentoTotal   Decimal?         @db.Decimal(15, 2)
  documentosProjeto   String?
  status              StatusUsina      @default(operacional)

  filial          Filial? @relation(fields: [filialId], references: [id], onDelete: Restrict)
  filialId        String?
  filialCodigoRaw String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  geracoes           Geracao[]
  vendasKwh          VendaKwh[]
  orcamentos         Orcamento[]
  cronogramasLimpeza CronogramaLimpeza[]
  manutencoesPrev    ManutencaoPreventiva[]
  consertos          ConsertoEquipamento[]
  manutencoesCorr    ManutencaoCorretiva[]
  licencas           Licenca[]

  @@index([nome])
  @@index([cnpj])
  @@index([filialId])
  @@index([status])
  @@index([deletedAt])
}

model Fornecedor {
  id     String  @id @default(cuid())
  zohoId String? @unique

  nome              String?
  cnpj              String?
  status            StatusEntidade @default(ativo)
  escopoServico     String?
  inicioPrestacao   DateTime?
  terminoPrestacao  DateTime?
  idContratoZoho    String?
  anexoContrato     String?
  abrangenciaUsinas String?

  abrangenciaFilial    Filial? @relation(fields: [abrangenciaFilialId], references: [id], onDelete: Restrict)
  abrangenciaFilialId  String?
  abrangenciaFilialRaw String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  consertos       ConsertoEquipamento[]
  manutencoesCorr ManutencaoCorretiva[]

  @@index([cnpj])
  @@index([status])
  @@index([abrangenciaFilialId])
  @@index([deletedAt])
}

// =============================================================================
// OPERATIONAL
// =============================================================================

model Geracao {
  id     String  @id @default(cuid())
  zohoId String? @unique

  ano         Int?
  mes         String?
  metaMensal  Decimal? @db.Decimal(12, 2)
  metaGeracao Decimal? @db.Decimal(12, 2)

  usina        Usina?  @relation(fields: [usinaId], references: [id], onDelete: Restrict)
  usinaId      String?
  nomeUsinaRaw String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  dias GeracaoDia[]

  @@index([usinaId])
  @@index([ano, mes])
  @@index([deletedAt])
}

/// Geração diária. Value-object filho de Geracao — `Cascade` intencional
/// (não é entidade de negócio, não faz sentido sem a Geracao pai).
model GeracaoDia {
  id        String   @id @default(cuid())
  geracao   Geracao  @relation(fields: [geracaoId], references: [id], onDelete: Cascade)
  geracaoId String
  dia       Int
  kwh       Decimal? @db.Decimal(12, 2)

  @@unique([geracaoId, dia])
  @@index([geracaoId])
}

/// Venda de KWh — uma linha por usina por mês (wide-to-long aplicado no seed).
model VendaKwh {
  id     String  @id @default(cuid())
  zohoId String?

  ano           Int
  mes           String
  kwhVendidos   Decimal? @db.Decimal(12, 2)
  valorReais    Decimal? @db.Decimal(15, 2)
  notaFiscalUrl String?

  usina        Usina?  @relation(fields: [usinaId], references: [id], onDelete: Restrict)
  usinaId      String?
  nomeUsinaRaw String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([zohoId, ano, mes])
  @@index([usinaId])
  @@index([ano, mes])
  @@index([deletedAt])
}

model Consumo {
  id     String  @id @default(cuid())
  zohoId String? @unique

  ano               Int?
  mes               String?
  uc                String?
  consumoKwhP       Decimal? @db.Decimal(12, 2)
  consumoKwhFp      Decimal? @db.Decimal(12, 2)
  consumoTotal      Decimal? @db.Decimal(12, 2)
  injecaoRecebida   Decimal? @db.Decimal(12, 2)
  multasJurosAtraso Decimal? @db.Decimal(15, 2)
  outrasMultas      Decimal? @db.Decimal(15, 2)
  valor             Decimal? @db.Decimal(15, 2)
  valor1            Decimal? @db.Decimal(15, 2)
  valor2            Decimal? @db.Decimal(15, 2)
  valor3            Decimal? @db.Decimal(15, 2)
  valorTotalFatura  Decimal? @db.Decimal(15, 2)
  statusAnexo       String?
  arquivoFatura     String?
  municipio         String?

  filial          Filial? @relation(fields: [filialId], references: [id], onDelete: Restrict)
  filialId        String?
  filialCodigoRaw String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  validacoes ValidacaoFatura[]

  @@index([filialId])
  @@index([ano, mes])
  @@index([uc])
  @@index([deletedAt])
}

model Injecao {
  id     String  @id @default(cuid())
  zohoId String? @unique

  ano             Int?
  mes             String?
  uc              String?
  filialDescricao String?
  fornecedorRaw   String?
  consumoKwhP     Decimal? @db.Decimal(12, 2)
  consumoKwhP1    Decimal? @db.Decimal(12, 2)
  consumoTotalKwh Decimal? @db.Decimal(12, 2)
  valor           Decimal? @db.Decimal(15, 2)
  valor1          Decimal? @db.Decimal(15, 2)
  valor2          Decimal? @db.Decimal(15, 2)
  municipio       String?
  anexoFechamento String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([ano, mes])
  @@index([uc])
  @@index([deletedAt])
}

model Orcamento {
  id     String  @id @default(cuid())
  zohoId String? @unique

  mes                 String?
  tipo                TipoOrcamento?
  naturezaGasto       String?
  detalhamento        String?
  equipamentos        String?
  realEquipamentos    Decimal?       @db.Decimal(15, 2)
  realViagensEstadias Decimal?       @db.Decimal(15, 2)
  realUsoConsumo      Decimal?       @db.Decimal(15, 2)
  usoConsumo          Decimal?       @db.Decimal(15, 2)
  anexosDetalhamento  String?

  usina        Usina?  @relation(fields: [usinaId], references: [id], onDelete: Restrict)
  usinaId      String?
  nomeUsinaRaw String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([usinaId])
  @@index([mes])
  @@index([deletedAt])
}

// =============================================================================
// MANUTENÇÃO
// =============================================================================

model CronogramaLimpeza {
  id     String  @id @default(cuid())
  zohoId String? @unique

  realizado   String?
  statusGeral StatusManutencao @default(pendente)

  usina        Usina?  @relation(fields: [usinaId], references: [id], onDelete: Restrict)
  usinaId      String?
  nomeUsinaRaw String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  itens LimpezaItem[]

  @@index([usinaId])
  @@index([statusGeral])
  @@index([deletedAt])
}

/// Value-object filho de CronogramaLimpeza — `Cascade` intencional.
model LimpezaItem {
  id            String            @id @default(cuid())
  cronograma    CronogramaLimpeza @relation(fields: [cronogramaId], references: [id], onDelete: Cascade)
  cronogramaId  String
  ordem         Int
  dataPlanejada DateTime?
  dataConclusao DateTime?
  status        StatusManutencao?
  fotoUrl       String?

  @@unique([cronogramaId, ordem])
  @@index([cronogramaId])
  @@index([dataPlanejada])
}

model ManutencaoPreventiva {
  id     String  @id @default(cuid())
  zohoId String? @unique

  status               StatusManutencao @default(pendente)
  dataExecucao         DateTime?
  dataConclusao        DateTime?
  laudoTecnico         String?
  fotosUsina           String?
  checklistVerificacao String?

  usina        Usina?  @relation(fields: [usinaId], references: [id], onDelete: Restrict)
  usinaId      String?
  nomeUsinaRaw String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([usinaId])
  @@index([status])
  @@index([dataExecucao])
  @@index([deletedAt])
}

// =============================================================================
// JURÍDICO
// =============================================================================

model ProcessoJuridico {
  id     String  @id @default(cuid())
  zohoId String? @unique

  tipo            TipoProcesso?
  parteAdversa    String?
  pleito          String?
  dataProtocolo   DateTime?
  fornecedor      String?
  evolucaoJaneiro String?
  /// Lista textual ("Gazin NAS II- Filial 265 - MS") — pode citar múltiplas
  /// usinas. Resolução pra FK fica para etapa futura.
  nomeUsinasRaw   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([tipo])
  @@index([dataProtocolo])
  @@index([deletedAt])
}

