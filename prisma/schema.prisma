  observacao String?

  usina        Usina?      @relation(fields: [usinaId], references: [id], onDelete: Restrict)
  usinaId      String?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id], onDelete: Restrict)
  fornecedorId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([usinaId])
  @@index([fornecedorId])
  @@index([deletedAt])
}

// STUB — schema preliminar, expandir quando JSON real for fornecido
model ManutencaoCorretiva {
  id String @id @default(cuid())

  observacao String?

  usina        Usina?      @relation(fields: [usinaId], references: [id], onDelete: Restrict)
  usinaId      String?
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id], onDelete: Restrict)
  fornecedorId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([usinaId])
  @@index([fornecedorId])
  @@index([deletedAt])
}

// STUB — schema preliminar, expandir quando JSON real for fornecido
model Documento {
  id String @id @default(cuid())

  observacao String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}
