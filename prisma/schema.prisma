// STUB — schema preliminar, expandir quando JSON real for fornecido
model Licenca {
  id String @id @default(cuid())

  observacao String?

  usina   Usina?  @relation(fields: [usinaId], references: [id], onDelete: Restrict)
  usinaId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([usinaId])
  @@index([deletedAt])
}

// STUB — schema preliminar, expandir quando JSON real for fornecido
model ValidacaoFatura {
  id String @id @default(cuid())

  observacao String?

  consumo   Consumo? @relation(fields: [consumoId], references: [id], onDelete: Restrict)
  consumoId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([consumoId])
  @@index([deletedAt])
}

// STUB — schema preliminar, expandir quando JSON real for fornecido
model ItemEstoque {
  id String @id @default(cuid())

  observacao String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

// STUB — schema preliminar, expandir quando JSON real for fornecido
model ConsertoEquipamento {
